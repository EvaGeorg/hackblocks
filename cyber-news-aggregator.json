  "diagram_notes": [
    {
      "content": "Stay on top of new security vulnerabilities and the latest news in cyber by receiving the news as they appear in a constant centralized space.\n\n\nThe story is built with these core actions:\n\n1. HTTP Request – fetch the feed (RSS / API)\n2. Trigger on change – detect new items only\n3. Event Transformation – explode feed into individual news items\n4. Slack Action – post each new item to Slack",
      "position": [
        -135,
        180
      ],
      "guid": "07634e607800fbf53560d7046bc7cf7e",
      "width": 270
    }
  ],
